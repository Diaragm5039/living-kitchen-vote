# ── Required ──
# Supabase connection string (Transaction pooler recommended)
# Get from: Supabase Dashboard → Settings → Database → Connection string → Pooler
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── Optional ──
ADMIN_PASSWORD=admin123
SESSION_SECRET=change-this-to-a-random-string
PORT=3000
